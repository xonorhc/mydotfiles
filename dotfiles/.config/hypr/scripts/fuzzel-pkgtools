#!/usr/bin/env bash

TERMINAL="kitty"

# Detect available AUR manager
if command -v paru >/dev/null 2>&1; then
  AUR_CMD="paru"
elif command -v yay >/dev/null 2>&1; then
  AUR_CMD="yay"
else
  AUR_CMD="sudo pacman"
fi

# 1. Choose installation type
install_type=$(echo -e "pacman\nflatpak" | fuzzel --dmenu --prompt "Packege manager:" --lines 2) || exit 0
[ -z "$install_type" ] && exit 0

# 2. Enter search term
search_term=$(fuzzel --dmenu --prompt "Buscar app:" --placeholder "Type the name...") || exit 0
[ -z "$search_term" ] && exit 0

# 3. Search packages and format list
declare -a pkgs_list

if [ "$install_type" = "pacman" ]; then
  while IFS= read -r line; do
    pkg_name=$(echo "$line" | awk '{print $1}' | cut -d'/' -f2)
    pkg_desc=$(echo "$line" | awk '{for(i=2;i<=NF;i++) printf "%s ", $i; print ""}')
    pkgs_list+=("$pkg_name — $pkg_desc")
  done < <(pacman -Ss "$search_term" | grep "^[^ ]")
elif [ "$install_type" = "flatpak" ]; then
  while IFS= read -r line; do
    name=$(echo "$line" | awk '{print $1}')
    desc=$(echo "$line" | cut -d' ' -f2-)
    pkgs_list+=("$name — $desc")
  done < <(flatpak search "$search_term" | tail -n +2)
fi

# 4. If no packages found
if [ ${#pkgs_list[@]} -eq 0 ]; then
  notify-send "Package not found '$search_term'"
  exit 0
fi

# 5. Select package in Fuzzel
selected_line=$(printf "%s\n" "${pkgs_list[@]}" | fuzzel --dmenu --prompt "Select a package:" --lines 15) || exit 0
[ -z "$selected_line" ] && exit 0

# 6. Extract name only
pkg_name=$(echo "$selected_line" | awk -F ' — ' '{print $1}')

# 7. Install on terminal
if [ "$install_type" = "pacman" ]; then
  $TERMINAL -e bash -c "$AUR_CMD -S $pkg_name"
elif [ "$install_type" = "flatpak" ]; then
  $TERMINAL -e bash -c "flatpak install flathub $pkg_name -y"
fi
