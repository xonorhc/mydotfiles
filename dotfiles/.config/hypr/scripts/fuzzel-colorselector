#!/usr/bin/env bash

declare -A colors

# TOKYONIGHT COLORS:
# colors=( ["¾░Åś Dark Blue"]="#16161e" ["¾░Åś Blue"]="#7aa2f7" ["¾░Åś Sky"]="#7dcfff" ["¾░Åś Teal"]="#4fd6be" ["¾░Åś Green"]="#9ece6a" ["¾░Åś Yellow"]="#e0af68" ["¾░Åś Orange"]="#f7768e" ["¾░Åś Pink"]="#bb9af7" ["¾░Åś Purple"]="#9d7cd8" ["¾░Åś Red"]="#f7768e")

# ROSEPINE COLORS:
# colors=( ["¾░Åś Rose"]="#f6c177" ["¾░Åś Pine"]="#31748f" ["¾░Åś Foam"]="#9ccfd8")

# CATPPUCCIN COLORS:
# colors=( ["¾░Åś Rosewater"]="#f5e0dc" ["¾░Åś Flamingo"]="#f2cdcd" ["¾░Åś Pink"]="#f5c2e7" ["¾░Åś Mauve"]="#cba6f7" ["¾░Åś Red"]="#f38ba8" ["¾░Åś Maroon"]="#eba0ac" ["¾░Åś Peach"]="#fab387" ["¾░Åś Yellow"]="#f9e2af" ["¾░Åś Green"]="#a6e3a1" ["¾░Åś Teal"]="#94e2d5" ["¾░Åś Sky"]="#89dceb" ["¾░Åś Sapphire"]="#74c7ec" ["¾░Åś Blue"]="#89b4fa" ["¾░Åś Lavender"]="#b4befe")

# MATERIAL COLORS:
# colors=( ["¾░Åś Red"]="#f44336" ["¾░Åś Pink"]="#e91e63" ["¾░Åś Purple"]="#9c27b0" ["¾░Åś Deep Purple"]="#673ab7" ["¾░Åś Indigo"]="#3f51b5" ["¾░Åś Blue"]="#2196f3" ["¾░Åś Light Blue"]="#03a9f4" ["¾░Åś Cyan"]="#00bcd4" ["¾░Åś Teal"]="#009688" ["¾░Åś Green"]="#4caf50" ["¾░Åś Amber"]="#ffc107" ["¾░Åś Orange"]="#ff9800" ["¾░Åś Deep Orange"]="#ff5722")

# DRACULA COLORS:
colors=(
  ["¾░Åś Cyan"]="#8be9fd"
  ["¾░Åś Green"]="#50fa7b"
  ["¾░Åś Orange"]="#ffb86c"
  ["¾░Åś Pink"]="#ff79c6"
  ["¾░Åś Purple"]="#bd93f9"
  ["¾░Åś Red"]="#ff5555"
  ["¾░Åś Yellow"]="#f1fa8c"
)

choice=$(for name in "${!colors[@]}"; do echo "$name"; done | sort |
  fuzzel --dmenu --prompt="¾▒ō¤ Choose a color (or type HEX color): " --width=30)

[ -z "$choice" ] && exit 0

if [[ ${colors[$choice]} ]]; then
  hex_color=${colors[$choice]}
else
  if [[ $choice =~ ^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$ ]]; then
    hex_color=$choice
  else
    notify-send "Color Selector" "Invalid HEX code!" --icon=error
    exit 1
  fi
fi

notify-send "Color Selector" "Generating theme for the color $hex_color..." --icon=color-management
matugen -t scheme-rainbow \
  --contrast 0.5 \
  -m dark \
  -r nearest \
  --continue-on-error \
  --fallback-color "#bd93f9" \
  --lightness-dark 0.05 \
  color hex "$hex_color"
notify-send "Color Selector" "Color $hex_color applied successfully!" -i color-select
