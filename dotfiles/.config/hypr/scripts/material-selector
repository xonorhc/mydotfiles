#!/usr/bin/env bash

# Definiأ§أ£o de algumas cores vibrantes do Material Design para o seletor
declare -A colors
colors=(
  ["َ°ڈک Red"]="#f44336"
  ["َ°ڈک Pink"]="#e91e63"
  ["َ°ڈک Purple"]="#9c27b0"
  ["َ°ڈک Deep Purple"]="#673ab7"
  ["َ°ڈک Indigo"]="#3f51b5"
  ["َ°ڈک Blue"]="#2196f3"
  ["َ°ڈک Light Blue"]="#03a9f4"
  ["َ°ڈک Cyan"]="#00bcd4"
  ["َ°ڈک Teal"]="#009688"
  ["َ°ڈک Green"]="#4caf50"
  ["َ°ڈک Amber"]="#ffc107"
  ["َ°ڈک Orange"]="#ff9800"
  ["َ°ڈک Deep Orange"]="#ff5722"
)

# Transforma o array em uma lista para o Fuzzel
choice=$(for name in "${!colors[@]}"; do echo "$name"; done | sort |
  fuzzel --dmenu --prompt="َ±“ں Escolha uma cor (ou digite o HEX): " --width=30)

# Sai se o usuأ،rio cancelar (ESC)
[ -z "$choice" ] && exit 0

# Verifica se a escolha estأ، no array ou se أ© um HEX manual
if [[ ${colors[$choice]} ]]; then
  hex_color=${colors[$choice]}
else
  # Valida se o que foi digitado أ© um HEX vأ،lido (ex: #ffffff)
  if [[ $choice =~ ^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$ ]]; then
    hex_color=$choice
  else
    notify-send "Matugen" "Cأ³digo HEX invأ،lido!" --icon=error
    exit 1
  fi
fi

# Dispara o Matugen
notify-send "Matugen" "Gerando tema para a cor $hex_color..." --icon=color-management
matugen color hex "$hex_color" --type scheme-fidelity

# No final do material-selector.sh
notify-send "Matugen" "Tema $hex_color aplicado com sucesso!" -i color-select
