{
  "custom/cava": {
    "exec": "$HOME/.config/waybar/scripts/cava.sh",
    "format": "{}",
    "format-icons": [
      "▁",
      "▂",
      "▃",
      "▄",
      "▅",
      "▆",
      "▇",
      "█"
    ],
    "restart-interval": 1,
    "kill-directive": "SIGKILL",
    "on-click": "kitty --class kitty-floating cava",
    "on-scroll-up": "playerctl previous",
    "on-scroll-down": "playerctl next",
    "on-click-right": "playerctl play-pause",
    "max-length": 35,
  },
}
