{
  "cpu": {
    "interval": 10,
    "format": "󰍛 {usage}%",
    "format-warning": "󰀧 {percentage}%",
    "format-critical": "󰀧 {percentage}%",
    "states": {
      "warning": 75,
      "critical": 90,
    },
    "min-length": 7,
    "max-length": 7,
    "on-click": "uwsm app -- kitty --class kitty-floating -e btop",
  },
}
